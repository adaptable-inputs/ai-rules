#!/bin/sh
# Generated artifacts must match the corpus they are generated from. An agent
# trusts MANIFEST.md and stops looking, so a stale one is worse than none.
#
# Enable once per clone:  git config core.hooksPath .githooks
set -e

root="$(git rev-parse --show-toplevel)"
cd "$root"

# Reflow prose in place. Each block is rewritten only if its normalized text and
# its obligation fingerprint are unchanged; otherwise the script aborts.
python3 scripts/fmt_prose.py
git add -u

python3 scripts/gen_manifest.py --check || {
    echo
    echo "pre-commit: MANIFEST.md does not match the frontmatter it is generated from."
    echo "pre-commit: run 'python3 scripts/gen_manifest.py' and stage the result."
    exit 1
}
python3 scripts/check_indexes_accurate.py
python3 scripts/check_structure.py

# markdownlint is the one gate CI runs that the hook did not, so a lint error
# could reach the branch. Skip only when the tool is genuinely unavailable, and
# say so -- a silent skip is a gate that cannot fail.
if command -v npx >/dev/null 2>&1; then
    npx --yes markdownlint-cli2@0.13.0 "**/*.md" "#node_modules" >/dev/null 2>&1 || {
        echo "pre-commit: markdownlint failed. Run:"
        echo "  npx markdownlint-cli2@0.13.0 '**/*.md' '#node_modules'"
        exit 1
    }
else
    echo "pre-commit: npx unavailable, markdownlint not run; CI will still check it"
fi
